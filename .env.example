# ---------------------------------------------------------------------------
# Back Nine Pulse Board — environment
#
# Copy to `.env.local` for local dev. Vite only exposes vars prefixed VITE_.
# The app ships with a mock data source by default, so none of these are
# required to run locally.
# ---------------------------------------------------------------------------

# Which data source the app polls. "mock" (default) reads local sample JSON.
# Swap to "live" once a real adapter is wired up in src/data/index.ts.
VITE_DATA_SOURCE=mock

# How often the UI polls the data adapter, in milliseconds. Default 5 min.
VITE_POLL_INTERVAL_MS=300000

# How often the kiosk does a full page reload to pick up new deploys, in ms.
# Default 30 min. Set to 0 to disable.
VITE_RELOAD_INTERVAL_MS=1800000

# Which layout to render: "auto" (default) picks by screen size — the 800×480
# panel gets the dense "mini" board, big displays get the "full" board.
# Force with "full" or "mini".
VITE_BOARD=auto

# ---------------------------------------------------------------------------
# Future real-source credentials (NOT used by the mock build).
#
# These are read by a backend/edge function, NOT the static site — never ship
# secrets in a client bundle. Left here to document what a live adapter needs.
# ---------------------------------------------------------------------------

# GoHighLevel — members, bookings, MRR
# GHL_API_KEY=
# GHL_LOCATION_ID=

# QuickBooks — revenue
# QBO_CLIENT_ID=
# QBO_CLIENT_SECRET=
# QBO_REFRESH_TOKEN=
# QBO_REALM_ID=

# Google Business Profile — rating + reviews
# GOOGLE_PLACE_ID=
# GOOGLE_API_KEY=
